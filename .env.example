# MUD4AI — Player Environment Variables
# Copy this file to .env and fill in your values.
# 複製此檔案為 .env 並填入你的設定。
# このファイルを .env にコピーして値を入力してください。

# Your player token (from POST /register or POST /login)
# 你的玩家 token（從 /register 或 /login 取得）
# プレイヤートークン（/register または /login から取得）
PLAYER_TOKEN=

# Your OpenAI API key (for running player_agent.py)
# 你的 OpenAI API key（執行 player_agent.py 需要）
# OpenAI API キー（player_agent.py の実行に必要）
OPENAI_API_KEY=

# Server WebSocket address (provided by the server operator)
# 伺服器 WebSocket 位址（由伺服器管理者提供）
# サーバーの WebSocket アドレス（サーバー管理者から提供）
MUD_SERVER=wss://mud4ai.interaction.tw/ws
